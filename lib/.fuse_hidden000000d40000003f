import { cookies } from "next/headers";
import { cache } from "react";
import { createHash, randomBytes } from "crypto";
import { createClient, createAdminClient } from "@/lib/supabase/server";

// ════════════════════════════════════════════════════════════════
// 2FA helpers (server-side).
//
// Stack: Supabase Auth nativo (TOTP). Para evitar pedir código a cada
// login, suportamos "trusted devices" via cookie HttpOnly + tabela com
// hash do token (ver 0049). Validade: 30 dias.
//
// Política aplicada: só admin/trainer/owner é forçado a 2FA. Clientes
// podem activar voluntariamente mas não é exigido em /admin/*.
// ════════════════════════════════════════════════════════════════

export const TRUSTED_DEVICE_COOKIE = "lf_td";
export const TRUSTED_DEVICE_DAYS = 30;

function hashToken(token: string): string {
  return createHash("sha256").update(token).digest("hex");
}

/** Lê os factores TOTP do utilizador autenticado. Devolve apenas os já
 *  verificados (configurados com sucesso). */
export async function listVerifiedFactors() {
  const supabase = await createClient();
  const { data, error } = await supabase.auth.mfa.listFactors();
  if (error || !data) return [];
  return (data.totp ?? []).filter((f) => f.status === "verified");
}

// PERF (audit #1, hot path): getAuthenticatorAssuranceLevel() SEM argumento
// é LOCAL — lê o cookie de sessão e descodifica o JWT, zero round-trip ao
// GoTrue. Devolve:
//   - currentLevel: o aal do JWT actual (aal1 = só password, aal2 = +2FA)
//   - hasMfa:       true se o user TEM factores verificados (nextLevel ===
//                   "aal2", lido de session.user.factors no cookie) — a
//                   forma LOCAL de saber "este user usa 2FA?" sem chamar
//                   listFactors()->getUser() (que é um round-trip de rede).
// Cached por request para deduplicar entre layout e páginas.
export const getAalInfo = cache(
  async (): Promise<{ currentLevel: "aal1" | "aal2"; hasMfa: boolean }> => {
    const supabase = await createClient();
    const { data } = await supabase.auth.mfa.getAuthenticatorAssuranceLevel();
    return {
      currentLevel: (data?.currentLevel as "aal1" | "aal2") ?? "aal1",
      hasMfa: data?.nextLevel === "aal2",
    };
  },
);

/** Devolve o "Authenticator Assurance Level" actual da sessão. */
export async function getAal(): Promise<"aal1" | "aal2"> {
  return (await getAalInfo()).currentLevel;
}

/** Verifica se há um cookie trusted-device VÁLIDO para o user dado. */
export async function isDeviceTrusted(userId: string): Promise<boolean> {
  const cookie = (await cookies()).get(TRUSTED_DEVICE_COOKIE)?.value;
  if (!cookie) return false;
  const supabase = createAdminClient();
  const { data } = await (supabase as any)
    .from("trusted_devices")
    .select("id, expires_at")
    .eq("user_id", userId)
    .eq("token_hash", hashToken(cookie))
    .gt("expires_at", new Date().toISOString())
    .limit(1)
    .maybeSingle();
  return !!data;
}

/** Conclusão geral: o utilizador satisfaz 2FA neste request?
 *  Verdadeiro se AAL >= 2 OU se tem cookie trusted-device válido. */
export async function isMfaSatisfied(userId: string): Promise<boolean> {
  if ((await getAal()) === "aal2") return true;
  return isDeviceTrusted(userId);
}

/** Marca este device como confiável durante TRUSTED_DEVICE_DAYS. */
export async function trustThisDevice(userId: string, userAgent?: string, ip?: string) {
  const token = randomBytes(32).toString("base64url");
  const expiresAt = new Date(Date.now() + TRUSTED_DEVICE_DAYS * 86_400_000);

  const supabase = createAdminClient();
  await (supabase as any).from("trusted_devices").insert({
    user_id: userId,
    token_hash: hashToken(token),
    user_agent: userAgent ?? null,
    ip: ip ?? null,
    expires_at: expiresAt.toISOString(),
  });

  (await cookies()).set(TRUSTED_DEVICE_COOKIE, token, {
    httpOnly: true,
    secure: process.env.NODE_ENV === "production",
    sameSite: "lax",
    path: "/",
    expires: expiresAt,
  });
}

