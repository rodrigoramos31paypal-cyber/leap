# ──────────────────────────────────────────────────────────────
# Supabase
# Encontras estes valores em: app.supabase.com → Project Settings → API
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ──────────────────────────────────────────────────────────────
# App
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=LEAP-FITNESS STUDIO

# ──────────────────────────────────────────────────────────────
# IfthenPay (deixar vazio até conta ser aprovada)
# Quando aprovado: backoffice.ifthenpay.com → "Chaves API"
# ──────────────────────────────────────────────────────────────
IFTHENPAY_ENABLED=false
IFTHENPAY_MBWAY_KEY=
IFTHENPAY_MULTIBANCO_KEY=
IFTHENPAY_CCARD_KEY=
IFTHENPAY_ANTI_PHISHING_KEY=
IFTHENPAY_CALLBACK_URL=https://your-domain.com/api/webhooks/ifthenpay
# SEC (H3): allow-list de IP do callback (defesa em profundidade).
# Vazio = desactivado (fail-open). Pede os IPs de origem ao suporte
# IfthenPay. Aceita IPs exactos e CIDR IPv4, separados por virgula.
# Ex.: IFTHENPAY_CALLBACK_ALLOWED_IPS=193.136.x.y,195.22.x.0/24
IFTHENPAY_CALLBACK_ALLOWED_IPS=

# ──────────────────────────────────────────────────────────────
# Emails · Resend (https://resend.com)
# Cria conta, verifica domínio, cria API key.
# ──────────────────────────────────────────────────────────────
NOTIFICATIONS_EMAIL_ENABLED=false
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=no-reply@leap-fitness.pt

# ──────────────────────────────────────────────────────────────
# Google Calendar OAuth (sync admin agenda → Google Calendar)
# Cria projeto em https://console.cloud.google.com → APIs & Services
# → Credentials → Create OAuth client (Web application)
# Authorized redirect URI: <APP_URL>/api/integrations/google/callback
# ──────────────────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ──────────────────────────────────────────────────────────────
# Microsoft OAuth (Outlook / Office 365)
# https://portal.azure.com → Azure AD → App registrations → New
# Redirect URI: <APP_URL>/api/integrations/microsoft/callback
# API permissions: Calendars.ReadWrite, offline_access
# ──────────────────────────────────────────────────────────────
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=

# ──────────────────────────────────────────────────────────────
# Upstash Redis · rate limiting (H1 do audit de segurança)
# https://console.upstash.com → Create database (Global, free tier)
# Copia REST URL + REST TOKEN.
#
# Se ambos ficarem vazios, o rate limiter degrada para no-op (útil
# em dev local). Em produção: defines os dois e atacas brute force
# em /login, /registar, /recuperar e /api/webhooks/ifthenpay ficam
# bloqueados após ~5 tentativas por minuto.
# ──────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ──────────────────────────────────────────────────────────────
# Alerting · sinais de segurança/integridade (#8 do hardening)
# Endpoint que recebe um POST JSON quando dispara um alerta:
#   • callback IfthenPay rejeitado/erro
#   • acção de admin recusada (access denied / _is_service_or_admin)
#   • create_booking sem sessões mas com créditos disponíveis
#
# Aceita um webhook Slack/Discord ou um tunnel Sentry. Se ficar vazio,
# os alertas continuam a ser emitidos como logs "[ALERT]" (capturáveis
# por log-drains). Ver lib/alerts.ts para ligar @sentry/nextjs/PostHog.
# ──────────────────────────────────────────────────────────────
ALERT_WEBHOOK_URL=
