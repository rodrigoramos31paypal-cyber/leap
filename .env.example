# ──────────────────────────────────────────────────────────────
# Supabase
# Encontras estes valores em: app.supabase.com → Project Settings → API
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ──────────────────────────────────────────────────────────────
# App
# PRODUÇÃO: NEXT_PUBLIC_APP_URL TEM de ser o domínio real (sem barra
# final). É usado nos links dos emails de conta/password — se ficar
# vazio ou errado, os links de confirmação/recuperação não funcionam.
# Define este valor nas Environment Variables da Vercel (Production).
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://leapfitnesstudio.com
NEXT_PUBLIC_APP_NAME=LEAP-FITNESS STUDIO

# Número MB WAY mostrado ao cliente nas instruções de pagamento manual.
NEXT_PUBLIC_PT_MBWAY_PHONE=912 478 768

# ──────────────────────────────────────────────────────────────
# Emails da APP · Resend (https://resend.com)
# (confirmações de marcação, lembretes, etc. — SEPARADO dos emails de
#  conta/password, que são enviados pelo Supabase Auth via SMTP.)
# Cria conta, verifica o domínio leapfitnesstudio.com, cria API key.
# Mantém NOTIFICATIONS_EMAIL_ENABLED=true em produção para ligar.
# ──────────────────────────────────────────────────────────────
NOTIFICATIONS_EMAIL_ENABLED=true
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=no-reply@leapfitnesstudio.com

# ──────────────────────────────────────────────────────────────
# Google Calendar OAuth (sync admin agenda → Google Calendar)
# Cria projeto em https://console.cloud.google.com → APIs & Services
# → Credentials → Create OAuth client (Web application)
# Authorized redirect URI: <APP_URL>/api/integrations/google/callback
# ──────────────────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ──────────────────────────────────────────────────────────────
# Microsoft OAuth (Outlook / Office 365)
# https://portal.azure.com → Azure AD → App registrations → New
# Redirect URI: <APP_URL>/api/integrations/microsoft/callback
# API permissions: Calendars.ReadWrite, offline_access
# ──────────────────────────────────────────────────────────────
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=

# ──────────────────────────────────────────────────────────────
# Upstash Redis · rate limiting (H1 / H-3 do audit de segurança)
# https://console.upstash.com → Create database (Global, free tier)
# Copia REST URL + REST TOKEN.
#
# OBRIGATÓRIO EM PRODUÇÃO (H-3, audit jun/2026).
#   • Sem Upstash em DEV → fallback in-memory por instância (basta para
#     desenvolvimento local).
#   • Sem Upstash em PROD → o limiter cai para in-memory por instância
#     serverless. Como o Vercel faz fan-out de instâncias, o limite
#     efectivo em login/registar passa a ser ~5 × Nº instâncias quentes
#     por minuto, e os contadores não sobrevivem a cold starts. A
#     protecção anti-brute-force fica materialmente mais fraca.
#     `lib/rate-limit.ts` já loga em `console.error` quando isto
#     acontece em produção — segue esse alerta no log drain.
#
# Buckets configurados (req/min): auth 5 · register 3 · webhook 60 ·
# export 5 · generic 30.
# ──────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ──────────────────────────────────────────────────────────────
# Alerting · sinais de segurança/integridade (#8 do hardening)
# Endpoint que recebe um POST JSON quando dispara um alerta:
#   • acção de admin recusada (access denied / _is_service_or_admin)
#   • create_booking sem sessões mas com créditos disponíveis
#
# Aceita um webhook Slack/Discord ou um tunnel Sentry. Se ficar vazio,
# os alertas continuam a ser emitidos como logs "[ALERT]" (capturáveis
# por log-drains). Ver lib/alerts.ts para ligar @sentry/nextjs/PostHog.
# ──────────────────────────────────────────────────────────────
ALERT_WEBHOOK_URL=
